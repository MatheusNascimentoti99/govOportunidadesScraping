# SMTP settings
SCRAPY_MAIL_USER=
SCRAPY_MAIL_PASS=
SCRAPY_MAIL_FROM=
SCRAPY_MAIL_HOST=
SCRAPY_MAIL_PORT=

# Key Words to be searched. Use commas to separate multiple keywords.
SCRAPY_KEY_WORDS=

# Email address to send notifications to
SCRAPY_MAIL_TO=your_email@example.com

# Path to the SQLite database file
EDITAIS_DB_PATH=editais.db

# OpenRouter API settings for edital text summarization
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-r1-0528:free
OPENROUTER_MAX_TEXT_LENGTH=4000